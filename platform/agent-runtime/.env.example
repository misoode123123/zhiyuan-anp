# 智源 ANP AI 运行时环境变量（复制为 .env 并填入真实值）

ENV=dev
AGENT_RUNTIME_PORT=8001

# 默认模型 —— 智谱 GLM（LiteLLM zhipu provider）
# 智谱开放平台支持的模型名：glm-4-flash(免费额度) / glm-4 / glm-4.6 / glm-5.1 等
DEFAULT_MODEL=zhipu/glm-4-flash

# 智谱 API Key（必填，申请：https://bigmodel.cn 控制台）
ZHIPUAI_API_KEY=

# 其他备用 provider（按需）
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
