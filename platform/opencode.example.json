{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zai-coding": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ZAI Coding",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/coding/paas/v4",
        "apiKey": "{env:ZHIPUAI_API_KEY}"
      },
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1",
          "reasoning": true,
          "limit": { "context": 204800, "output": 131072 }
        },
        "glm-5-turbo": {
          "name": "GLM-5-Turbo",
          "reasoning": true,
          "limit": { "context": 204800, "output": 131072 }
        }
      }
    }
  }
}
