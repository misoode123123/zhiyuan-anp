# ===== 智源 ANP 平台环境变量样例 =====
# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略）

# 运行环境
ENV=dev
LOG_LEVEL=debug

# ---- 数据库（M0 先用 SQLite；切 PG 时改这里）----
DATABASE_URL=sqlite://./tmp/anp.db
# PG 示例（装 Docker 后启用）:
# DATABASE_URL=postgres://anp:anp@localhost:5432/anp?sslmode=disable

# ---- 缓存 / 对象存储（Docker 起后启用）----
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---- Go 后端 ----
BACKEND_HTTP_ADDR=:8080
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Python AI 运行时（Go 经 HTTP 调用，M0）----
AGENT_RUNTIME_URL=http://localhost:8001

# ---- 模型 API（任选其一填，用于 LiteLLM 网关）----
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
# 默认模型（LiteLLM 模型串）
DEFAULT_MODEL=deepseek/deepseek-chat
