# ===== 智源 ANP 平台环境变量样例 =====
# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略）

# 运行环境
ENV=dev
LOG_LEVEL=debug

# ---- 数据库（开发/生产强制 PostgreSQL,禁 SQLite）----
# 本地 dev.sh 已内置连 .28 dev PG;此处仅作覆盖示例:
# DATABASE_URL=postgres://anp:anp_dev_pwd@10.10.0.28:5432/anp_dev?sslmode=disable
# 生产连 anp PG(部署时 deploy/.env.prod 配)

# ---- 缓存 / 对象存储（Docker 起后启用）----
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---- Go 后端 ----
BACKEND_HTTP_ADDR=:8080
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Python AI 运行时（Go 经 HTTP 调用，M0）----
AGENT_RUNTIME_URL=http://localhost:8001

# ---- 模型 API（任选其一填，用于 LiteLLM 网关）----
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
# 默认模型（LiteLLM 模型串）
DEFAULT_MODEL=deepseek/deepseek-chat
